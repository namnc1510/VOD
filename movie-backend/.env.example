PORT=3001
# Local development database
MONGO_URI=mongodb://127.0.0.1:27017/The-Movie
# Mongo tuning (optional)
MONGO_MAX_POOL_SIZE=20
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JSON_LIMIT=100kb
# Max upload size (MB) for /api/v1/upload
UPLOAD_MAX_FILE_SIZE_MB=5120
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Dev override to avoid 429 spam while clicking around admin UIs
RATE_LIMIT_MAX_DEV=10000
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-another-strong-secret
JWT_REFRESH_EXPIRES_IN=30d

# Optional: Cloudinary for /api/v1/upload
# Recommended: set CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# CLOUDINARY_URL=
# Or split vars:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=movie-uploads

SEED_RESET=true
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_DEMO_EMAIL=
SEED_DEMO_PASSWORD=

# Local -> Atlas data promotion
SOURCE_MONGO_URI=mongodb://127.0.0.1:27017/The-Movie
ATLAS_MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/The-Movie?retryWrites=true&w=majority
ATLAS_SYNC_COLLECTIONS=categories,countries,qualities,formats,persons,movies,episodes,settings,users,comments,watchlists,transactions,role_permissions

# VNPAY
VNP_TMNCODE=
VNP_HASHSECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURNURL=http://localhost:3001/api/v1/payment/vnpay-return
VNP_IPNURL=http://localhost:3001/api/v1/payment/vnpay-ipn
FRONTEND_PAYMENT_SUCCESS_URL=http://localhost:5173/payment/success
FRONTEND_PAYMENT_ERROR_URL=http://localhost:5173/payment/error
