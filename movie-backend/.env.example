PORT=3001
MONGO_URI=mongodb://127.0.0.1:27017/The-Movie
# Mongo tuning (optional)
MONGO_MAX_POOL_SIZE=20
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JSON_LIMIT=100kb
# Max upload size (MB) for /api/v1/upload
UPLOAD_MAX_FILE_SIZE_MB=5120
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Dev override to avoid 429 spam while clicking around admin UIs
RATE_LIMIT_MAX_DEV=10000
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d

# Optional: Cloudinary for /api/v1/upload
# Recommended: set CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# CLOUDINARY_URL=
# Or split vars:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=movie-uploads

SEED_RESET=true
SEED_ADMIN_EMAIL=admin@streamvue.local
SEED_ADMIN_PASSWORD=Admin@123456
SEED_DEMO_EMAIL=demo@streamvue.local
SEED_DEMO_PASSWORD=Demo@123456
