# --- BACKEND PRODUCTION CONFIGURATION ---
# Replace the values below with your actual production settings

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/The-Movie?retryWrites=true&w=majority

# Secret for JWT signing (use a long random string)
JWT_SECRET=your_very_long_random_production_secret

# CORS: URL of your Vercel frontend
CORS_ORIGINS=https://vod-ten.vercel.app

# Port (Render usually sets this automatically)
PORT=3001

# --- VNPAY ---
# Replace with your real merchant/sandbox configuration
VNP_TMNCODE=
VNP_HASHSECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# Use your deployed backend domain here, not localhost
VNP_RETURNURL=https://your-backend-domain/api/v1/payment/vnpay-return
VNP_IPNURL=https://your-backend-domain/api/v1/payment/vnpay-ipn

# Use your deployed frontend domain here, not localhost
FRONTEND_PAYMENT_SUCCESS_URL=https://your-frontend-domain/payment/success
FRONTEND_PAYMENT_ERROR_URL=https://your-frontend-domain/payment/error

# --- CLOUDINARY (Optional) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
